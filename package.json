    "express": "^4.19.2",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^5.5.0",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^22.15.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
