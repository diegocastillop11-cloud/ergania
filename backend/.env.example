# ── Supabase (obligatorio) ────────────────────────────────────────────────────
# Obtené estos valores en: supabase.com > tu proyecto > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Opcional: proveedor de IA por defecto del servidor ────────────────────────
# Si no se configura, cada usuario debe ingresar su propia API key en el navegador
# DEFAULT_LLM_PROVIDER=gemini

# ── Frontend URL (para CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
PORT=4001
